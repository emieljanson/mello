[Unit]
Description=Berry go-librespot Spotify Connect
After=network.target
Wants=network.target
PartOf=berry-native.service

[Service]
Type=simple
User=berry
SupplementaryGroups=audio
ExecStart=/usr/local/bin/go-librespot --config_dir /home/berry/.config/go-librespot
Restart=always
RestartSec=5
Environment=HOME=/home/berry
Environment=XDG_RUNTIME_DIR=/run/user/1000
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus

[Install]
WantedBy=multi-user.target

