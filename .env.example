# Anonymous usage data sharing is configured during install (setup.sh).
# The setting is stored in data/settings.json and cannot be changed via the UI.
#
# To send analytics to your own PostHog project instead, set your key here:
# POSTHOG_API_KEY=phc_your_key_here
# POSTHOG_HOST=https://us.i.posthog.com

# Keep this fixed if you want one stable device in PostHog.
# Example: ANALYTICS_DISTINCT_ID=mello-livingroom
ANALYTICS_DISTINCT_ID=

# Privacy defaults are strict; keep these off unless you need detail.
ANALYTICS_INCLUDE_CONTENT=0
# For multiple Pi devices, set this to 1 to keep each Pi unique.
ANALYTICS_USE_MACHINE_ID=1
